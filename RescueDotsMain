package com.zetcode;

import javax.swing.*;
import java.awt.*;

public class RescueDots extends JFrame {

    public RescueDots() {

        initUI();
    }
    
    private void initUI() {
        RescueDotsSurface surface = new RescueDotsSurface();
        this.add(surface);
       this.setTitle("RescueDots");
        this.setSize(1280, 1024);
        surface.setBackground(Color.pink);
        this.setLocationRelativeTo(null);
    }

    public static void main(String[] args) {
        EventQueue.invokeLater(new Runnable() {
            @Override
            public void run() {
                RescueDots ex = new RescueDots();
                ex.setVisible(true);
            }
        });
    }
}
